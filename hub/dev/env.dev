# @saflib/env
ALLOW_DB_CREATION=true
DEPLOYMENT_NAME=development
MOCK_INTEGRATIONS=true
NODE_ENV=development
PROTOCOL=http
TZ=UTC

# Hub domain model (all products)
TRADEMARK=Hub
DOMAIN=docker.localhost
CLIENT_SUBDOMAINS=,app,auth,account,admin,recipes,app.recipes,admin.recipes,account.recipes,notebook,app.notebook,admin.notebook,account.notebook
SERVICE_SUBDOMAINS=identity,api.recipes,api.notebook,hub

# @saflib/identity-*
IDENTITY_SERVICE_HTTP_HOST=monolith:3000
IDENTITY_SERVICE_GRPC_HOST=monolith:50051
IDENTITY_SERVICE_ADMIN_EMAILS=admin@sderickson.com
IDENTITY_SERVICE_DISABLE_RATE_LIMITING=true
SENTRY_DSN=

# @saflib/email (Brevo wins when set; else nodemailer JSON)
BREVO_API_KEY=
NODEMAILER_TRANSPORT_CONFIG=

# Product service hosts (all on monolith)
HUB_SERVICE_HTTP_HOST=monolith:3001
RECIPES_SERVICE_HTTP_HOST=monolith:3002
NOTEBOOK_SERVICE_HTTP_HOST=monolith:3003

# Integrations
INFISICAL_TOKEN=mock
KRATOS_COURIER_HTTP_HOST=monolith:3000
SENTRY_DSN=mock

ADMIN_EMAILS=sderickson@gmail.com