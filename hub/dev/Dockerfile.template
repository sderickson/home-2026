# syntax=docker/dockerfile:labs
# Recipes static clients for hub dev (recipes.* on Caddy)

FROM node:24-slim AS builder

WORKDIR /app

#{ copy_packages }#
RUN npm install --omit=dev

#{ copy_src }#

WORKDIR /app/recipes/clients/build
RUN DOMAIN=docker.localhost CLIENT_SUBDOMAINS=recipes,app.recipes,admin.recipes,account.recipes SERVICE_SUBDOMAINS=api.recipes DEPLOYMENT_NAME=development TZ=UTC npm run build

FROM caddy:2.11.2
COPY --from=builder /app/recipes/clients/build/dist /srv/recipes-clients
