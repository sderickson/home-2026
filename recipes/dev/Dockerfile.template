# syntax=docker/dockerfile:labs

# Requires a local tag first: recipes/dev npm scripts run `docker build` on
# recipes/clients/static-root before compose (compose builds services in parallel).
# Logged-out recipes marketing site — same base image as deploy (recipes/clients/static-root).
FROM sderickson-recipes-static-root:latest AS static-root-builder
RUN npm run build

# Monorepo install once — workspace closure of @sderickson/recipes-dev (hub static builds for this stack).
FROM node:24-slim AS deps

WORKDIR /app

#{ copy_packages }#
RUN npm install --omit=dev

#{ copy_src }#

# Hub static clients for recipes dev (hub.* subdomains)
FROM deps AS hub-builder

WORKDIR /app/hub/clients/build
RUN DOMAIN=docker.localhost CLIENT_SUBDOMAINS=,app,auth,account,admin SERVICE_SUBDOMAINS=identity DEPLOYMENT_NAME=development TZ=UTC npm run build

FROM caddy:2.11.2
COPY --from=hub-builder /app/hub/clients/build/dist /srv/hub-clients
COPY --from=static-root-builder /app/recipes/clients/static-root/.vitepress/dist /srv/recipes-static-root
