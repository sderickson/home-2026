# @saflib/env
ALLOW_DB_CREATION=true
DEPLOYMENT_NAME=development
MOCK_INTEGRATIONS=true
NODE_ENV=development
PROTOCOL=http
TZ=UTC

# Hub domain model
TRADEMARK=Recipes
DOMAIN=docker.localhost
CLIENT_SUBDOMAINS=,app,auth,account,admin,recipes,app.recipes,admin.recipes,account.recipes
SERVICE_SUBDOMAINS=identity,api.recipes

# @saflib/ory-kratos (courier on monolith :3000)
KRATOS_COURIER_HTTP_HOST=monolith:3000
SENTRY_DSN=

# @saflib/email
NODEMAILER_TRANSPORT_CONFIG=

# @sderickson/recipes-http
RECIPES_SERVICE_HTTP_HOST=monolith:3002

# Integrations
AZURE_CLIENT_ID=testkeyfordev
AZURE_HOT_BLOB_STORAGE_URL=http://azurite:10000/devstoreaccount1/
AZURE_COLD_BLOB_STORAGE_URL=http://azurite:10000/devstoreaccount1/

# Admin emails
ADMIN_EMAILS=sderickson@gmail.com

