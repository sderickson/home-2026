# Caddy env for hub domain model (single domain, Kratos + product APIs)
# Used by deploy/remote-assets/config/Caddyfile

DOMAIN=scotterickson.info
PROTOCOL=https
HUB_SERVICE_HTTP_HOST=monolith:3001
RECIPES_SERVICE_HTTP_HOST=monolith:3002
NOTEBOOK_SERVICE_HTTP_HOST=monolith:3003

# Optional: redirect old/wrong hostnames to main domain (comma-separated)
DOMAIN_REDIRECTS=http://dne.docker.localhost

BLOCK_ADMIN_PAGES=true
