# Single hub monolith: Kratos courier + hub + recipes
# One domain; API subdomains use Kratos whoami in Caddy.

ALLOW_DB_CREATION=true
CLIENT_SUBDOMAINS=,app,auth,account,admin,recipes,app.recipes,admin.recipes,account.recipes,grafana
DEPLOYMENT_NAME=production
DOMAIN=scotterickson.info
MOCK_INTEGRATIONS=false
NODE_ENV=production
PROTOCOL=https

KRATOS_COURIER_HTTP_HOST=monolith:3000

SERVICE_SUBDOMAINS=hub,api.recipes
TRADEMARK="Hub"
TZ=UTC

HUB_SERVICE_HTTP_HOST=monolith:3001
RECIPES_SERVICE_HTTP_HOST=monolith:3002

LOKI_HOSTNAME=loki
LOKI_PORT=3100

ADMIN_EMAILS=sderickson@gmail.com