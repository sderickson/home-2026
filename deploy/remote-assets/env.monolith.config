# Single hub monolith: Kratos courier + hub + recipes + notebook (Phase 6)
# One domain; API subdomains use Kratos whoami in Caddy.

ALLOW_DB_CREATION=true
CLIENT_SUBDOMAINS=,app,auth,account,admin,recipes,app.recipes,admin.recipes,account.recipes,notebook,app.notebook,admin.notebook,account.notebook,grafana
DEPLOYMENT_NAME=production
DOMAIN=scotterickson.info
MOCK_INTEGRATIONS=false
NODE_ENV=production
PROTOCOL=https

KRATOS_COURIER_HTTP_HOST=monolith:3000

SERVICE_SUBDOMAINS=identity,hub,api.recipes,api.notebook
TRADEMARK="Hub"
TZ=UTC

HUB_SERVICE_HTTP_HOST=monolith:3001
RECIPES_SERVICE_HTTP_HOST=monolith:3002
NOTEBOOK_SERVICE_HTTP_HOST=monolith:3003

LOKI_HOSTNAME=loki
LOKI_PORT=3100